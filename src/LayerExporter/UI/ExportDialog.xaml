<Window x:Class="LayerExporter.UI.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="레이어 내보내기 (DXF / SHP)"
        Width="440" Height="700"
        MinWidth="380" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 좌표계: 도면 좌표 지정 / 위성사진으로 좌표 확인 -->
        <GroupBox Grid.Row="0" Header="좌표계 설정" Margin="0,0,0,6">
            <StackPanel Margin="4">
                <DockPanel Margin="0,2">
                    <Button DockPanel.Dock="Left" Content="좌표선택" Width="110" Padding="8,2"
                            ToolTip="도면 좌표계/지오 위치를 지정합니다 (Civil 3D: MAPCSASSIGN, 일반 AutoCAD: GEOGRAPHICLOCATION 자동 적용)"
                            Click="OnAssignCoordinateSystem"/>
                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray"
                               Text="도면 좌표계/지오 위치 지정"/>
                </DockPanel>
                <DockPanel Margin="0,2">
                    <Button DockPanel.Dock="Left" Content="위성사진 켜기" Width="110" Padding="8,2"
                            ToolTip="GEOMAP 위성사진(하이브리드)을 켭니다. 창을 열어둔 채 도면을 확대/축소/이동해 좌표를 확인하세요."
                            Click="OnGeoMapOn"/>
                    <Button DockPanel.Dock="Left" Content="위성사진 끄기" Width="110" Padding="8,2" Margin="6,0,0,0"
                            ToolTip="위성사진(GEOMAP)을 끕니다."
                            Click="OnGeoMapOff"/>
                    <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Foreground="Gray" TextWrapping="Wrap"
                               Text="켠 뒤 도면에서 휠로 확대/축소·이동"/>
                </DockPanel>
            </StackPanel>
        </GroupBox>

        <!-- 대상 선택 방식: 객체 선택이 우선(먼저) -->
        <GroupBox Grid.Row="1" Header="① 내보낼 대상 선택" Margin="0,0,0,6">
            <StackPanel Margin="4">
                <!-- 객체 선택 (우선) -->
                <RadioButton Content="객체 선택 (고른 객체만 내보내기)" IsChecked="{Binding IsObjectMode}"
                             FontWeight="SemiBold" Margin="0,2"/>
                <DockPanel Margin="20,2,0,6" IsEnabled="{Binding IsObjectMode}">
                    <Button DockPanel.Dock="Right" Content="화면에서 객체 선택" Padding="8,2" Margin="8,0,0,0"
                            ToolTip="도면에서 객체를 선택하면 기존 선택에 추가됩니다"
                            Click="OnPickObjectsFromScreen"/>
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="현재 "/><Run Text="{Binding SelectedObjectCount, Mode=OneWay}" FontWeight="Bold"/><Run Text="개 객체 선택됨"/>
                    </TextBlock>
                </DockPanel>

                <!-- 레이어 선택 -->
                <RadioButton Content="레이어 선택 (선택 레이어의 모든 객체 내보내기)" IsChecked="{Binding IsLayerMode}"
                             FontWeight="SemiBold" Margin="0,2"/>
            </StackPanel>
        </GroupBox>

        <!-- 레이어 필터 + 화면 선택 + 전체선택 (레이어 모드에서만 활성) -->
        <DockPanel Grid.Row="2" Margin="0,0,0,6" IsEnabled="{Binding LayerSelectionEnabled}">
            <CheckBox x:Name="SelectAllCheck" DockPanel.Dock="Right" Content="전체 선택"
                      VerticalAlignment="Center" Margin="8,0,0,0"
                      Checked="OnSelectAllChecked" Unchecked="OnSelectAllUnchecked"/>
            <Button DockPanel.Dock="Right" Content="화면에서 레이어 선택" Padding="8,2" Margin="8,0,0,0"
                    ToolTip="도면에서 객체를 선택하면 해당 객체가 속한 레이어가 자동으로 체크됩니다"
                    Click="OnPickLayersFromScreen"/>
            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center" Height="26"
                     ToolTip="레이어 이름 필터"/>
        </DockPanel>

        <!-- 레이어 목록 -->
        <ListBox Grid.Row="3" ItemsSource="{Binding LayersView}"
                 IsEnabled="{Binding LayerSelectionEnabled}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox IsChecked="{Binding IsSelected}" Margin="2">
                        <TextBlock>
                            <Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold"/>
                            <Run Text="{Binding Description, Mode=OneWay}" Foreground="Gray"/>
                        </TextBlock>
                    </CheckBox>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- 출력 형식 (DXF/SHP 개별 또는 동시 선택) -->
        <GroupBox Grid.Row="4" Header="② 출력 형식 (둘 다 선택 가능)" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Margin="4">
                <CheckBox Content="SHP (Shapefile)" IsChecked="{Binding ExportShp}" Margin="0,0,16,0"/>
                <CheckBox Content="DXF" IsChecked="{Binding ExportDxf}"/>
            </StackPanel>
        </GroupBox>

        <!-- 출력 경로 -->
        <GroupBox Grid.Row="5" Header="③ 출력 위치" Margin="0,8,0,0">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="폴더:" VerticalAlignment="Center" Margin="0,0,6,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" VerticalContentAlignment="Center" Margin="0,0,0,4"/>
                <Button Grid.Row="0" Grid.Column="2" Content="찾아보기..." Padding="8,2" Margin="6,0,0,4"
                        Click="OnBrowseFolder"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="이름:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                         Text="{Binding BaseName, UpdateSourceTrigger=PropertyChanged}"
                         Height="26" VerticalContentAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- 옵션 (SHP 전용) -->
        <GroupBox Grid.Row="6" Header="SHP 옵션" Margin="0,8,0,0"
                  IsEnabled="{Binding ExportShp}">
            <StackPanel Margin="4">
                <CheckBox Content="닫힌 폴리선을 폴리곤으로 변환" IsChecked="{Binding ClosedPolylinesAsPolygons}" Margin="0,2"/>
                <CheckBox Content="Z 좌표 포함 (PointZ/PolylineZ)" IsChecked="{Binding IncludeZ}" Margin="0,2"/>
                <DockPanel Margin="0,2">
                    <TextBlock Text="곡선 분할 허용오차:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding Tolerance, UpdateSourceTrigger=PropertyChanged}"
                             Width="80" Height="24" HorizontalAlignment="Left" VerticalContentAlignment="Center"/>
                </DockPanel>
            </StackPanel>
        </GroupBox>

        <!-- 버튼 -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="내보내기" Width="90" Height="28" IsDefault="True" Click="OnExport"/>
            <Button Content="닫기" Width="70" Height="28" Click="OnCancel" Margin="8,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
