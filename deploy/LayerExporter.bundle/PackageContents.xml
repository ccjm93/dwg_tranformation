<?xml version="1.0" encoding="utf-8"?>
<ApplicationPackage SchemaVersion="1.0" AutodeskProduct="AutoCAD" ProductType="Application"
    Name="LayerExporter" AppVersion="1.0.0"
    Description="선택한 레이어를 DXF 또는 SHP(Shapefile)로 내보내는 Civil 3D 플러그인"
    Author="jungmin">
  <CompanyDetails Name="jungmin" />

  <!-- Civil 3D / AutoCAD 2018–2024 (R22.0–R24.3, .NET Framework 4.8) -->
  <Components Description="Civil 3D / AutoCAD 2018-2024">
    <RuntimeRequirements OS="Win64" Platform="AutoCAD*" SeriesMin="R22.0" SeriesMax="R24.3" />
    <ComponentEntry AppName="LayerExporter" ModuleName="./Contents/2018/LayerExporter.dll"
        AppDescription="레이어 DXF/SHP 내보내기" LoadOnAutoCADStartup="True">
      <Commands GroupName="LAYEREXPORTER">
        <Command Global="DwgToSHP" Local="DwgToSHP" />
      </Commands>
    </ComponentEntry>
  </Components>

  <!-- Civil 3D / AutoCAD 2025–2026 (R25.0–R25.1, .NET 8) -->
  <Components Description="Civil 3D / AutoCAD 2025-2026">
    <RuntimeRequirements OS="Win64" Platform="AutoCAD*" SeriesMin="R25.0" SeriesMax="R25.1" />
    <ComponentEntry AppName="LayerExporter" ModuleName="./Contents/2025/LayerExporter.dll"
        AppDescription="레이어 DXF/SHP 내보내기" LoadOnAutoCADStartup="True">
      <Commands GroupName="LAYEREXPORTER">
        <Command Global="DwgToSHP" Local="DwgToSHP" />
      </Commands>
    </ComponentEntry>
  </Components>

  <!-- Civil 3D / AutoCAD 2027 (R26.0, .NET 10) -->
  <Components Description="Civil 3D / AutoCAD 2027">
    <RuntimeRequirements OS="Win64" Platform="AutoCAD*" SeriesMin="R26.0" SeriesMax="R26.0" />
    <ComponentEntry AppName="LayerExporter" ModuleName="./Contents/2027/LayerExporter.dll"
        AppDescription="레이어 DXF/SHP 내보내기" LoadOnAutoCADStartup="True">
      <Commands GroupName="LAYEREXPORTER">
        <Command Global="DwgToSHP" Local="DwgToSHP" />
      </Commands>
    </ComponentEntry>
  </Components>
</ApplicationPackage>
